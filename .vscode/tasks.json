{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "desktop: build contracts",
      "type": "process",
      "command": "corepack",
      "args": ["pnpm", "--filter", "@syncflow/contracts", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "desktop: build design tokens",
      "type": "process",
      "command": "corepack",
      "args": ["pnpm", "--filter", "@syncflow/design-tokens", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "desktop: build shared packages",
      "dependsOn": ["desktop: build contracts", "desktop: build design tokens"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "desktop: dev",
      "type": "process",
      "command": "corepack",
      "args": ["pnpm", "--filter", "@syncflow/desktop", "dev"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["desktop: build shared packages"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*(ready in|watching for file changes|Local:).*"
        }
      }
    },
    {
      "label": "desktop: package win",
      "type": "process",
      "command": "corepack",
      "args": ["pnpm", "--filter", "@syncflow/desktop", "package:win"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["desktop: build shared packages"],
      "problemMatcher": []
    },
    {
      "label": "mobile: start metro",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/scripts/dev/ensure-mobile-metro.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*(Welcome to React Native|Starting Metro|Metro already running).*",
          "endsPattern": ".*Metro launch requested.*"
        }
      }
    },
    {
      "label": "mobile: stop metro",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/scripts/dev/stop-mobile-metro.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "mobile: run android",
      "type": "process",
      "command": "corepack",
      "args": [
        "pnpm",
        "--filter",
        "@syncflow/mobile",
        "exec",
        "react-native",
        "run-android",
        "--no-packager"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["mobile: start metro"],
      "problemMatcher": []
    }
  ]
}
