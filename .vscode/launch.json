{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mobile: Android CN Debug (F5)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && SYNCFLOW_ANDROID_APP_ID=com.vividrop.mobile.china SYNCFLOW_ANDROID_METRO_READY_TIMEOUT_SECONDS=180 bash scripts/dev/run-mobile-android-device.sh"
    },
    {
      "name": "Mobile: Android Global Debug (F5)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && SYNCFLOW_ANDROID_APP_ID=com.vividrop.mobile.global SYNCFLOW_ANDROID_METRO_READY_TIMEOUT_SECONDS=180 bash scripts/dev/run-mobile-android-device.sh"
    },
    {
      "name": "Mobile: iOS CN (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && SYNCFLOW_MARKET=cn bash scripts/dev/run-mobile-ios-device.sh"
    },
    {
      "name": "Mobile: iOS Global (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && SYNCFLOW_MARKET=global bash scripts/dev/run-mobile-ios-device.sh"
    },
    {
      "name": "Mobile: iOS CN Simulator (no Metro)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile exec react-native run-ios --scheme \"SyncFlowMobile\" --mode \"Debug\" --no-packager"
    },
    {
      "name": "Mobile: iOS Global Simulator (no Metro)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile exec react-native run-ios --scheme \"SyncFlowMobileGlobal\" --mode \"DebugGlobal\" --no-packager"
    },
    {
      "name": "Mobile: Metro (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile start"
    },
    {
      "name": "Desktop: Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/desktop dev"
    }
  ],
  "compounds": [
    {
      "name": "Mobile: Android + iOS",
      "configurations": [
        "Mobile: Android CN Debug (F5)",
        "Mobile: iOS CN Simulator (no Metro)"
      ],
      "stopAll": false
    }
  ]
}
