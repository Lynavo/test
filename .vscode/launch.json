{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mobile: Android Debug (F5)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && LYNAVO_ANDROID_METRO_READY_TIMEOUT_SECONDS=180 bash scripts/dev/run-mobile-android-device.sh"
    },
    {
      "name": "Mobile: Android Emulator (F5)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && LYNAVO_ANDROID_DEVICE=emulator-5554 LYNAVO_ANDROID_METRO_READY_TIMEOUT_SECONDS=180 bash scripts/dev/run-mobile-android-device.sh"
    },
    {
      "name": "Mobile: iOS (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && bash scripts/dev/run-mobile-ios-device.sh"
    },
    {
      "name": "Mobile: iOS Simulator (no Metro)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @lynavo-drive/mobile exec react-native run-ios --scheme \"LynavoDrive\" --mode \"Debug\" --no-packager"
    },
    {
      "name": "Mobile: Metro (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @lynavo-drive/mobile start"
    },
    {
      "name": "Desktop: Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @lynavo-drive/desktop dev"
    }
  ],
  "compounds": [
    {
      "name": "Mobile: Android + iOS",
      "configurations": [
        "Mobile: Android Debug (F5)",
        "Mobile: iOS Simulator (no Metro)"
      ],
      "stopAll": false
    }
  ]
}
