{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mobile: Android Debug (F5)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile exec react-native run-android --mode debug --no-packager"
    },
    {
      "name": "Mobile: iOS (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && bash scripts/dev/run-mobile-ios-device.sh"
    },
    {
      "name": "Mobile: iOS Simulator (no Metro)",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "mobile: start metro",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile exec react-native run-ios --no-packager"
    },
    {
      "name": "Mobile: Metro (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile start"
    },
    {
      "name": "Desktop: Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/desktop dev"
    }
  ],
  "compounds": [
    {
      "name": "Mobile: Android + iOS",
      "configurations": [
        "Mobile: Android Debug (F5)",
        "Mobile: iOS Simulator (no Metro)"
      ],
      "stopAll": false
    }
  ]
}
