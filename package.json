{
  "name": "syncflow",
  "private": true,
  "engines": { "node": ">=20", "pnpm": ">=10" },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:desktop": "pnpm --filter @syncflow/desktop dev",
    "build:desktop": "pnpm --filter @syncflow/desktop build",
    "dev:mobile": "pnpm --filter @syncflow/mobile start",
    "build:mobile": "cd apps/mobile/ios && xcodebuild -workspace SyncFlowMobile.xcworkspace -scheme SyncFlowMobile -destination 'generic/platform=iOS' -configuration Debug build",
    "dev:sidecar": "cd services/sidecar-go && make run",
    "build:sidecar": "cd services/sidecar-go && make build",
    "package:desktop": "pnpm build && pnpm --filter @syncflow/desktop package",
    "test:sidecar": "cd services/sidecar-go && make test",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "turbo run build test typecheck",
    "clean": "turbo run clean && rm -rf node_modules/.cache .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.0",
    "turbo": "^2.8.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.26.0"
  }
}
