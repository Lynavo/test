{
  "name": "vivi-drop",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm sync:versions:check && turbo run build",
    "dev": "turbo run dev",
    "dev:desktop": "pnpm --filter @syncflow/desktop dev",
    "build:desktop": "pnpm --filter @syncflow/desktop build",
    "dev:mobile": "pnpm --filter @syncflow/mobile start",
    "dev:mobile:android": "pnpm --filter @syncflow/mobile android",
    "build:mobile": "cd apps/mobile/ios && xcodebuild -workspace SyncFlowMobile.xcworkspace -scheme SyncFlowMobile -destination 'generic/platform=iOS' -configuration Debug build",
    "build:mobile:android": "pnpm --filter @syncflow/mobile build:android",
    "dev:sidecar": "cd services/sidecar-go && make run",
    "build:sidecar": "cd services/sidecar-go && make build",
    "package:desktop": "pnpm build && pnpm --filter @syncflow/desktop package",
    "package:desktop:win": "pnpm --filter @syncflow/desktop package:win",
    "package:desktop:signed": "pnpm --filter @syncflow/desktop package:signed",
    "package:desktop:signed:dir": "pnpm --filter @syncflow/desktop package:signed:dir",
    "package:mobile:testflight:archive": "pnpm --filter @syncflow/mobile archive:testflight",
    "package:mobile:testflight:upload": "pnpm --filter @syncflow/mobile upload:testflight",
    "package:mobile:testflight": "pnpm --filter @syncflow/mobile release:testflight",
    "release": "node scripts/release/release.mjs",
    "tag:beta": "bash ./scripts/release/create-beta-tag.sh",
    "tag:beta:push": "bash ./scripts/release/create-beta-tag.sh --push",
    "test:sidecar": "cd services/sidecar-go && make test",
    "test:release": "node --test scripts/release/__tests__/*.mjs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:vscode-android-debug": "node scripts/verify-vscode-android-debug.mjs",
    "verify:android-syncengine-bridge": "node scripts/verify-android-syncengine-bridge-parity.mjs",
    "sync:versions": "node scripts/sync-version-manifest.mjs",
    "sync:versions:check": "node scripts/sync-version-manifest.mjs --check",
    "check": "pnpm sync:versions:check && turbo run build test typecheck",
    "clean": "turbo run clean && rm -rf node_modules/.cache .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.0",
    "turbo": "^2.8.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.26.0"
  }
}
