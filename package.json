{
  "name": "lynavo-drive",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm sync:versions:check && turbo run build",
    "dev": "turbo run dev",
    "dev:desktop": "pnpm --filter @lynavo-drive/desktop dev",
    "dev:desktop:prod": "node scripts/dev/run-release-profile.mjs --profile prod --target desktop",
    "build:desktop": "pnpm --filter @lynavo-drive/desktop build",
    "dev:mobile": "pnpm --filter @lynavo-drive/mobile start",
    "dev:mobile:metro:prod": "node scripts/dev/run-release-profile.mjs --profile prod --target mobile-metro",
    "dev:mobile:ios:prod": "node scripts/dev/run-release-profile.mjs --profile prod --target mobile-ios",
    "dev:mobile:ios-device:prod": "node scripts/dev/run-release-profile.mjs --profile prod --target mobile-ios-device",
    "dev:mobile:android": "pnpm --filter @lynavo-drive/mobile android",
    "dev:mobile:android:prod": "node scripts/dev/run-release-profile.mjs --profile prod --target mobile-android",
    "profile:mobile:prod": "node scripts/dev/run-release-profile.mjs --profile prod --target mobile-metro --set-mobile-profile-only",
    "profile:mobile:reset": "node scripts/dev/run-release-profile.mjs --reset-mobile-profile",
    "build:mobile": "cd apps/mobile/ios && xcodebuild -workspace LynavoDrive.xcworkspace -scheme LynavoDrive -destination 'generic/platform=iOS' -configuration Debug CODE_SIGNING_ALLOWED=NO build",
    "build:mobile:ios:release": "pnpm --filter @lynavo-drive/mobile build:ios:release",
    "build:mobile:android": "pnpm --filter @lynavo-drive/mobile build:android",
    "dev:sidecar": "cd services/sidecar-go && make run",
    "build:sidecar": "cd services/sidecar-go && make build",
    "package:desktop": "pnpm build && pnpm --filter @lynavo-drive/desktop package",
    "package:desktop:win": "pnpm --filter @lynavo-drive/desktop package:win",
    "package:desktop:linux": "pnpm --filter @lynavo-drive/desktop package:linux",
    "release": "node scripts/release/release.mjs",
    "test:sidecar": "cd services/sidecar-go && make test",
    "test:release": "node --test scripts/release/__tests__/*.mjs scripts/dev/__tests__/*.mjs",
    "gate:release": "pnpm sync:versions:check && pnpm verify:oss-source-package:worktree && pnpm verify:oss-source-package:head && pnpm test:release && pnpm release --profile review --targets ios,android,mac,win,linux --dry-run && pnpm release --profile prod --targets ios,android,mac,win,linux --dry-run",
    "verify:release-tag": "node scripts/release/verify-release-tag.mjs",
    "assemble:release-assets": "node scripts/release/assemble-release-assets.mjs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:oss-source-package": "node scripts/verify-oss-source-package.mjs",
    "verify:oss-source-package:worktree": "node scripts/verify-oss-source-package.mjs --include-untracked",
    "verify:oss-source-package:head": "node scripts/verify-oss-source-package.mjs --git-ref HEAD",
    "verify:oss-source-package:advisory": "node scripts/verify-oss-source-package.mjs --advisory",
    "verify:vscode-android-debug": "node scripts/verify-vscode-android-debug.mjs",
    "verify:android-syncengine-bridge": "node scripts/verify-android-syncengine-bridge-parity.mjs",
    "sync:versions": "node scripts/sync-version-manifest.mjs",
    "sync:versions:check": "node scripts/sync-version-manifest.mjs --check",
    "check": "pnpm gate:release && turbo run build test typecheck",
    "clean": "turbo run clean && rm -rf node_modules/.cache .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.0",
    "turbo": "^2.8.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.26.0",
    "yaml": "^2.8.2"
  }
}
