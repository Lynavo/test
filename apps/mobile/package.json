{
  "name": "@lynavo-drive/mobile",
  "version": "1.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --max-warnings 0",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "test": "jest --no-watchman",
    "import:i18n": "python3 ./scripts/import_i18n_workbook.py",
    "build": "cd ios && xcodebuild -workspace LynavoDrive.xcworkspace -scheme LynavoDrive -destination 'generic/platform=iOS' -configuration Debug CODE_SIGNING_ALLOWED=NO build",
    "build:ios:release": "cd ios && xcodebuild -workspace LynavoDrive.xcworkspace -scheme LynavoDrive -destination 'generic/platform=iOS' -configuration Release CODE_SIGNING_ALLOWED=NO build",
    "build:android": "cd android && ./gradlew assembleDebug",
    "bundle": "react-native bundle --platform ios --dev true --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios"
  },
  "dependencies": {
    "@lynavo-drive/contracts": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-documents/viewer": "4.0.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/stack": "^7.8.6",
    "i18next": "^23.16.8",
    "lucide-react-native": "0.577.0",
    "react": "19.2.3",
    "react-i18next": "^15.7.4",
    "react-native": "0.84.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-keychain": "^10.0.0",
    "react-native-localize": "^3.7.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-share": "12.3.1",
    "react-native-svg": "^15.15.4",
    "react-native-vector-icons": "^10.3.0",
    "react-native-video": "^6.19.1",
    "react-native-vision-camera": "4.7.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/codegen": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/gradle-plugin": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.57.1",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.7",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.12.0"
  }
}
