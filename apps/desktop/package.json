{
  "name": "@lynavo-drive/desktop",
  "productName": "LynavoDriveDemo",
  "description": "LynavoDriveDemo desktop app for local mobile media sync.",
  "version": "1.0.1",
  "lynavoDriveBuildNumber": "62",
  "homepage": "https://github.com/lynavo/lynavo-drive",
  "author": {
    "name": "Lynavo",
    "url": "https://github.com/lynavo/lynavo-drive"
  },
  "private": true,
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node ./scripts/run-electron-vite.cjs dev",
    "build": "electron-vite build",
    "build:sidecar": "rm -f ./resources/lynavo-drive-sidecar && cd ../../services/sidecar-go && go build -o ../../apps/desktop/resources/lynavo-drive-sidecar ./cmd/lynavo-drive-sidecar/",
    "build:sidecar:mac": "node ./scripts/build-sidecar-mac.cjs universal",
    "build:sidecar:win": "node ./scripts/build-sidecar-win.cjs",
    "build:sidecar:linux": "node ./scripts/build-sidecar-linux.cjs",
    "package": "node ./scripts/run-workspace-pnpm.cjs build && pnpm build:sidecar:mac && node ./scripts/run-electron-builder.cjs --mac dmg --arm64 --x64",
    "package:all": "node ./scripts/run-workspace-pnpm.cjs build && pnpm build:sidecar && node ./scripts/run-electron-builder.cjs --mac",
    "package:win": "node ./scripts/run-workspace-pnpm.cjs build && node ./scripts/run-workspace-pnpm.cjs --filter @lynavo-drive/desktop build:sidecar:win && node ./scripts/verify-windows-resources.cjs && node ./scripts/run-electron-builder.cjs --win nsis zip --x64",
    "package:linux": "node ./scripts/package-linux.cjs",
    "preview": "node ./scripts/run-electron-vite.cjs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src/",
    "clean": "rm -rf dist out .turbo",
    "predev": "node ./scripts/run-workspace-pnpm.cjs --filter @lynavo-drive/contracts build && node ./scripts/run-workspace-pnpm.cjs --filter @lynavo-drive/design-tokens build"
  },
  "dependencies": {
    "@lynavo-drive/contracts": "workspace:*",
    "@lynavo-drive/design-tokens": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-log": "^5.4.3",
    "i18next": "^23.16.8",
    "lucide-react": "^0.577.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-qr-code": "^2.0.18",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
