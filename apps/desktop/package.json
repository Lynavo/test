{
  "name": "@syncflow/desktop",
  "productName": "SyncFlow",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node ./scripts/run-electron-vite.cjs dev",
    "build": "electron-vite build",
    "build:sidecar": "cd ../../services/sidecar-go && go build -o ../../apps/desktop/resources/syncflow-sidecar ./cmd/syncflow-sidecar/",
    "build:sidecar:win": "node ./scripts/build-sidecar-win.cjs",
    "package": "node ./scripts/run-workspace-pnpm.cjs build && pnpm build:sidecar && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "package:signed": "bash ./scripts/package-macos-signed.sh dmg",
    "package:signed:dir": "bash ./scripts/package-macos-signed.sh dir",
    "package:all": "node ./scripts/run-workspace-pnpm.cjs build && pnpm build:sidecar && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "package:win": "node ./scripts/run-workspace-pnpm.cjs build && node ./scripts/run-workspace-pnpm.cjs --filter @syncflow/desktop build:sidecar:win && node ./scripts/run-electron-builder.cjs --win zip --x64",
    "preview": "node ./scripts/run-electron-vite.cjs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src/",
    "clean": "rm -rf dist out .turbo",
    "predev": "node ./scripts/run-workspace-pnpm.cjs --filter @syncflow/contracts build && node ./scripts/run-workspace-pnpm.cjs --filter @syncflow/design-tokens build"
  },
  "dependencies": {
    "@syncflow/contracts": "workspace:*",
    "@syncflow/design-tokens": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-log": "^5.4.3",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
